{
   "name": "aiman",
   "version": "0.1.0",
   "private": false,
   "description": "Human-first Bun/TypeScript terminal workbench",
   "type": "module",
   "main": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "bin": {
      "aiman": "./dist/cli.js"
   },
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "import": "./dist/index.js"
      }
   },
   "scripts": {
      "dev": "bun run src/cli.ts",
      "build": "tsc -p tsconfig.build.json",
      "install:global": "bun run build && npm link",
      "uninstall:global": "npm unlink -g aiman",
      "typecheck": "tsc -p tsconfig.json --noEmit",
      "lint": "oxlint -c .oxlintrc.json src test --deny warnings",
      "lint:fix": "bun run lint -- --fix",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "test": "bun test test/*.ts*",
      "test:ui": "bun test test/ui-workbench.test.tsx",
      "test:provider-contract": "bun test ./test/provider-contract.ts",
      "skills": "bunx skills add",
      "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
      "prepare": "husky"
   },
   "dependencies": {
      "@opentui/core": "^0.1.96",
      "@opentui/react": "^0.1.96",
      "chalk": "^5.6.2",
      "gray-matter": "^4.0.3",
      "react": "^19.2.4",
      "yargs": "^18.0.0",
      "zod": "^4.3.6"
   },
   "devDependencies": {
      "@types/bun": "^1.3.11",
      "@types/node": "^25.5.0",
      "@types/react": "^19.2.14",
      "@types/yargs": "^17.0.35",
      "husky": "^9.1.7",
      "lint-staged": "^16.4.0",
      "oxlint": "^1.57.0",
      "prettier": "^3.8.1",
      "tsx": "^4.21.0",
      "typescript": "^6.0.2"
   }
}
