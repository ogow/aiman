{
   "name": "aiman",
   "version": "0.1.0",
   "private": true,
   "description": "Node 25 TypeScript CLI scaffold",
   "type": "module",
   "packageManager": "npm@11.4.2",
   "engines": {
      "node": ">=25 <26"
   },
   "bin": {
      "aiman": "./dist/cli.js"
   },
   "scripts": {
      "dev": "tsx src/cli.ts",
      "build": "tsc -p tsconfig.build.json",
      "typecheck": "tsc -p tsconfig.json --noEmit",
      "lint": "oxlint -c .oxlintrc.json src test --deny warnings",
      "lint:fix": "npm run lint -- --fix",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "test": "node --import tsx --test test/**/*.test.ts",
      "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
      "prepare": "husky"
   },
   "lint-staged": {
      "*.{ts,js,mjs,cjs}": [
         "oxlint -c .oxlintrc.json --fix --quiet"
      ],
      "*.{json,md,yml,yaml}": [
         "prettier --write"
      ]
   },
   "dependencies": {
      "gray-matter": "^4.0.3",
      "yargs": "^18.0.0"
   },
   "devDependencies": {
      "@types/node": "^25.5.0",
      "@types/yargs": "^17.0.35",
      "husky": "^9.1.7",
      "lint-staged": "^16.4.0",
      "oxlint": "^1.57.0",
      "prettier": "^3.8.1",
      "tsx": "^4.21.0",
      "typescript": "^6.0.2"
   }
}
